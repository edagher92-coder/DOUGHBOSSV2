# DoughBoss — example environment file. Copy to `.env` (git-ignored) or set these
# as real environment variables / WordPress constants / CI secrets on the host.
#
# NEVER commit real values. Every secret below is read *env-first* by
# includes/class-doughboss-settings.php (env/constant wins over the stored
# option). Leaving one blank keeps the integration DORMANT — the plugin ships
# safe with nothing configured. Set only the ones you are turning on.
#
# In wp-config.php you can instead do:  define( 'DOUGHBOSS_STRIPE_TEST_SK', '...' );

# --- Stripe (slice 2: payments) ---------------------------------------------
# Test + live secret keys and webhook signing secrets. Test mode is used until
# live mode is explicitly enabled in DoughBoss → Settings → Payments.
DOUGHBOSS_STRIPE_TEST_SK=
DOUGHBOSS_STRIPE_TEST_WHSEC=
DOUGHBOSS_STRIPE_LIVE_SK=
DOUGHBOSS_STRIPE_LIVE_WHSEC=

# --- Tyro Connect Pay (current online-payments integration) ----------------
# PRE-FINAL: leaving every value blank keeps Tyro dormant. Client IDs are
# configured in wp-admin; secrets/signing keys stay server-side. Do not assume
# an undeclared environment variable is supported for the client ID.
# Each DoughBoss shop must also have its Tyro Connect locationId mapped under
# DoughBoss -> Shops / Locations before that shop can accept online payment.
# Production additionally requires Tyro technical approval and the explicit
# live-certification gate in wp-admin. These values do not turn payments live.
DOUGHBOSS_TYRO_TEST_CLIENT_SECRET=
DOUGHBOSS_TYRO_TEST_WHSEC=
DOUGHBOSS_TYRO_LIVE_CLIENT_SECRET=
DOUGHBOSS_TYRO_LIVE_WHSEC=

# --- POSPal (slice 4: POS mirror) -------------------------------------------
# Open Platform app key per store (store 1 = APPKEY, stores 2/3 = _2 / _3).
DOUGHBOSS_POSPAL_APPKEY=
DOUGHBOSS_POSPAL_APPKEY_2=
DOUGHBOSS_POSPAL_APPKEY_3=

# --- Real-time + notifications (slice 6) ------------------------------------
DOUGHBOSS_MERCURE_PUBLISH_JWT=   # Mercure hub publish JWT (server-side only)
DOUGHBOSS_NTFY_TOKEN=            # ntfy push topic token
DOUGHBOSS_CLICKSEND_API_KEY=     # ClickSend SMS API key
DOUGHBOSS_PRINTER_TOKEN=         # CloudPRNT / Epson printer-pull token
